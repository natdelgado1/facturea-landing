# ============================================
# FACTUREA LANDING - Variables de Entorno
# ============================================
# Copia este archivo a .env y completa los valores
# cp .env.example .env

# ============================================
# Google Analytics 4 (REQUERIDO)
# ============================================
# ID de medición de Google Analytics (obligatorio en producción: Vercel / Docker / CI).
# Debe coincidir con: GA4 → Administrar → Flujos de datos → [tu web] → ID de medición (G-…).
# Si falta en build de producción, el sitio NO carga GA4 (evita enviar a un ID equivocado).
# Obtener en: https://analytics.google.com/
PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# true = enviar hits en modo depuración (aparecen en GA4 → Administrar → DebugView). Útil en staging.
PUBLIC_GA_DEBUG=false

# ============================================
# Google Tag Manager (opcional)
# ============================================
# ID de contenedor de GTM
# Obtener en: https://tagmanager.google.com/
PUBLIC_GTM_ID=GTM-XXXXXXX

# ============================================
# Hotjar - Heatmaps y grabaciones (opcional)
# ============================================
# ID de sitio de Hotjar
# Obtener en: https://www.hotjar.com/
PUBLIC_HOTJAR_ID=

# ============================================
# Facebook Pixel (opcional)
# ============================================
# ID de pixel de Facebook
# Obtener en: https://business.facebook.com/events_manager
PUBLIC_FACEBOOK_PIXEL_ID=

# ============================================
# Calendario de asesoría (Google Calendar)
# ============================================
# URL pública de reserva (calendar.app.google / appointment schedule)
PUBLIC_ADVISOR_CALENDAR_URL=https://calendar.app.google/Ybw5yTj1PQ3wPKpW7

# ============================================
# reCAPTCHA v3 (REQUERIDO para formularios)
# ============================================
# Site Key de reCAPTCHA v3
# Obtener en: https://www.google.com/recaptcha/admin
RECAPTCHA_SITE_KEY=6LeXXXXXXXXXXXXXXXXXXXXXXXXXXXX
